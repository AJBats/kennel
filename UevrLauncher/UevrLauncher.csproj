<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <RootNamespace>UevrLauncher</RootNamespace>
    <AssemblyName>Kennel</AssemblyName>
    <Product>Kennel</Product>
    <AssemblyTitle>Kennel</AssemblyTitle>
    <Description>UEVR launcher manager for Steam</Description>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Version>0.1.0</Version>
    <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System.Web.Extensions" />
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.IO.Compression.FileSystem" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Templates\smart_wrap.bat.tmpl" />
    <EmbeddedResource Include="Templates\smart_wrap.vbs.tmpl" />
  </ItemGroup>

</Project>
