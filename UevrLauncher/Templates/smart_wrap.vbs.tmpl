' Invisible wrapper around {{BatFileName}}. Hides cmd window, waits for completion.
' Generated by Kennel. Do not edit by hand; use the GUI.
Set objShell = CreateObject("WScript.Shell")
q = Chr(34)
strBat = "{{BatPath}}"
strArgs = ""
For i = 0 To WScript.Arguments.Count - 1
    strArgs = strArgs & " " & q & WScript.Arguments(i) & q
Next
strCmd = "cmd /c " & q & q & strBat & q & strArgs & q
' style 0 = hidden, True = wait for completion
objShell.Run strCmd, 0, True
