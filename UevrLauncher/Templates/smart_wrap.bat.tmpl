@echo off
REM Smart launcher for {{GameName}} (Steam library entry).
REM Generated by Kennel. Do not edit by hand; use the GUI.
REM Kennel-GameExe={{GameExe}}
REM Kennel-Delay={{Delay}}
REM Kennel-UevrBuild={{UevrBuild}}
REM Kennel-Manual={{Manual}}
setlocal
tasklist /FI "IMAGENAME eq vrserver.exe" 2>NUL | find /I "vrserver.exe" >NUL
if "%ERRORLEVEL%"=="0" goto :vr
REM --- Flat mode ---
%*
exit /b %ERRORLEVEL%
:vr
REM Switch to UTF-8 so cmd parses non-ASCII characters (e.g. ™ in game
REM install paths) the same way Kennel wrote them. Scoped to the VR
REM branch only; the flat-mode passthrough above stays under the
REM caller's original codepage so tasklist/find behave as expected.
chcp 65001 >NUL
{{VrBlock}}
:no_chihuahua
mshta "javascript:alert('Kennel: required VR tooling is missing.\n\nOpen Kennel to reinstall.\nLaunching in flat mode.');close();"
%*
exit /b %ERRORLEVEL%
